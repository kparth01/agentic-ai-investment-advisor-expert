"""
LangServe server for Mental Wellness Agent.
Exposes the multi-agent workflow as a REST API.
"""
import os
from dotenv import load_dotenv

load_dotenv()

from fastapi import FastAPI
from fastapi.middleware.cors import CORSMiddleware
from langserve import add_routes
from pydantic import BaseModel, Field
from graph import app as investment_graph


class InvestmentInput(BaseModel):
    user_input: str = Field(description="what are the key financial indicators for my investment?")


app = FastAPI(
    title="Investment Expert Agent",
    version="1.0",
    description="A multi-agent investment expert API powered by LangGraph",
)

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
    expose_headers=["*"],
)

@app.get("/")
def root():
    return {
        "status": "ok",
        "docs": "/docs",
        "playground": "/investment/playground/",
    }

add_routes(
    app,
    investment_graph.with_types(input_type=InvestmentInput),
    path="/investment",
)

if __name__ == "__main__":
    import uvicorn

    port = int(os.getenv("PORT", 8000))
    uvicorn.run(app, host="0.0.0.0", port=port)